<script>
  function toggleFaq(el) {
    el.classList.toggle('open');
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = e.target.classList.contains('featured') ? 'scale(1.04)' : 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.pricing-card').forEach(el => {
    el.style.opacity = '0';
    observer.observe(el);
  });
</script>
